# Real inventory and secrets never get committed.
inventory/hosts.ini
inventory/group_vars/*/vault.yml
!inventory/group_vars/*/vault.yml.example

# Vault password, if you choose to keep it in a file rather than a keychain.
.vault_pass
.vault_pass.txt

# Runtime artefacts
.facts_cache/
*.retry

# Host-specific configuration names real servers and describes what else runs
# on them. This repository is public.
inventory/host_vars/
!inventory/host_vars/*.example.yml
