{#
  Rendered twice on a first run: once without TLS so certbot can answer the
  HTTP-01 challenge, then again once the certificate exists. `_stunprobe_vhost_tls`
  is set by the calling task. `_tlsrep_nginx_version` comes from the nginx role.
#}
{% set tls = _stunprobe_vhost_tls | default(false) %}
# {{ ansible_managed }}
# stun-probe.<domain> — WebRTC-forgery probe API + embeddable widget.
# The container is host-networked: it serves HTTP on 127.0.0.1:{{ tlsrep_stunprobe_http_port }}
# (proxied below) and binds the STUN UDP range directly for internet reach.

server {
    listen 80;
    listen [::]:80;
    server_name {{ tlsrep_stunprobe_domain }};

    location ^~ /.well-known/acme-challenge/ {
        root {{ tlsrep_acme_webroot }};
        default_type "text/plain";
    }
{% if tls %}
    location / { return 301 https://{{ tlsrep_stunprobe_domain }}$request_uri; }
{% else %}
    location / { return 503; }
{% endif %}
}
{% if tls %}
server {
{% if _tlsrep_nginx_version is version('1.25.1', '>=') %}
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
{% else %}
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
{% endif %}
    server_name {{ tlsrep_stunprobe_domain }};

    ssl_certificate     {{ tlsrep_stunprobe_le_dir }}/fullchain.pem;
    ssl_certificate_key {{ tlsrep_stunprobe_le_dir }}/privkey.pem;
    ssl_trusted_certificate {{ tlsrep_stunprobe_le_dir }}/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:TLSREPSTUN:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;
    ssl_stapling on;
    ssl_stapling_verify on;

    # Safe headers only — deliberately NO X-Frame-Options and NO restrictive
    # CSP. This whole origin is an embeddable widget: the app sets its own
    # `Content-Security-Policy: frame-ancestors *` so it can be iframed while
    # its inline script and the `stun:` ICE URL keep working. There is nothing
    # to clickjack here (read-only, no auth, no forms).
    add_header Strict-Transport-Security "max-age={{ tlsrep_hsts_max_age | default(63072000) }}; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    limit_conn tlsrep_conn 32;

    location / {
        # Each /init allocates a UDP port from a bounded pool; a rate cap keeps
        # a flood from exhausting it faster than the reaper frees it.
        limit_req zone=tlsrep_api burst={{ tlsrep_api_rate_burst | default(40) }} nodelay;
        proxy_pass http://127.0.0.1:{{ tlsrep_stunprobe_http_port }};
    }
}
{% endif %}
