# {{ ansible_managed }}
# Host-local connections only. There is no entry for any routable interface by
# design: the API runs on this host, as a container, and reaches the database
# over loopback or the Docker bridge.

# TYPE  DATABASE        USER            ADDRESS                 METHOD

# Administration over the unix socket, peer-authenticated. This is how Ansible
# manages roles and databases without a stored superuser password.
local   all             postgres                                peer

# The application over loopback TCP, password-authenticated. Kept for psql
# from the host itself even though the container no longer uses it.
local   {{ tlsrep_db_name }}   {{ tlsrep_db_user }}                            scram-sha-256
host    {{ tlsrep_db_name }}   {{ tlsrep_db_user }}       127.0.0.1/32         scram-sha-256
host    {{ tlsrep_db_name }}   {{ tlsrep_db_user }}       ::1/128              scram-sha-256

# The backend container, over the Docker bridge. Scoped to the one database
# and the one role, and still password-authenticated -- being on the bridge
# grants nothing on its own. The subnet is pinned in the `docker` role's
# daemon.json (bip), so it cannot drift out from under this line.
host    {{ tlsrep_db_name }}   {{ tlsrep_db_user }}       {{ tlsrep_docker_bridge_subnet }}      scram-sha-256

# Replication is unused; left peer-only rather than removed so pg_basebackup
# from the host itself still works for ad-hoc backups.
local   replication     all                                     peer
